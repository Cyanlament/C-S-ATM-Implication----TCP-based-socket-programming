{
  "name": "ts-atm",
  "version": "1.0.0",
  "private": true,
  "description": "Homework 2 ATM implementation with TypeScript + Electron",
  "main": "dist/src/client/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:server": "npm run build && node dist/src/server.js",
    "start:client": "npm run build && electron dist/src/client/main.js",
    "test:case": "npm run build && node dist/scripts/test_case.js",
    "pack:portable": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\package-ts.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^35.0.0",
    "typescript": "^5.7.0"
  }
}
